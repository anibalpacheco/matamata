{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/playoff-diagrams/spec/schema.json",
  "title": "Playoff bracket source document",
  "type": "object",
  "required": ["rounds"],
  "additionalProperties": false,
  "properties": {
    "tournament": { "type": "string", "minLength": 1 },
    "season": { "type": "string" },
    "render": { "$ref": "#/$defs/render" },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/round" }
    }
  },
  "$defs": {
    "render": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_label_chars": {
          "type": "integer",
          "minimum": 1,
          "default": 22
        },
        "box_width": {
          "type": "integer",
          "minimum": 60,
          "default": 190
        }
      }
    },
    "round": {
      "type": "object",
      "required": ["name", "matches"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "matches": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/match" }
        }
      }
    },
    "match": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "comment": "two sides, 1 = top, 2 = bottom; winnerof{n} wires the bracket, team{n} names a known side",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "winnerof1": { "type": "string", "minLength": 1 },
        "winnerof2": { "type": "string", "minLength": 1 },
        "team1": { "type": "string", "minLength": 1 },
        "team2": { "type": "string", "minLength": 1 },
        "seed1": { "type": "integer", "minimum": 1 },
        "seed2": { "type": "integer", "minimum": 1 },
        "id1": { "type": ["string", "integer"] },
        "id2": { "type": ["string", "integer"] },
        "legs": {
          "type": "array",
          "items": { "$ref": "#/$defs/leg" }
        },
        "winner": { "enum": [1, 2] }
      },
      "if": {
        "required": ["legs"],
        "properties": { "legs": { "minItems": 1 } }
      },
      "then": {
        "comment": "with legs the teams come from the legs, so only the bracket wiring is allowed",
        "not": {
          "anyOf": [
            { "required": ["team1"] },
            { "required": ["team2"] },
            { "required": ["seed1"] },
            { "required": ["seed2"] },
            { "required": ["id1"] },
            { "required": ["id2"] }
          ]
        }
      }
    },
    "leg": {
      "type": "object",
      "oneOf": [
        {
          "additionalProperties": false,
          "required": ["ref"],
          "properties": {
            "ref": { "type": ["string", "integer"] }
          }
        },
        {
          "additionalProperties": false,
          "required": ["team1", "goals1", "team2", "goals2"],
          "properties": {
            "team1": { "type": "string", "minLength": 1 },
            "goals1": { "type": "integer", "minimum": 0 },
            "id1": { "type": ["string", "integer"] },
            "pen1": { "type": "integer", "minimum": 0 },
            "team2": { "type": "string", "minLength": 1 },
            "goals2": { "type": "integer", "minimum": 0 },
            "id2": { "type": ["string", "integer"] },
            "pen2": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    }
  }
}
