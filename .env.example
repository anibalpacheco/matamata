# Local machine config for the Makefile and scripts/regen-docs.sh.
# Copy to .env (gitignored) and adjust for your machine. The syntax is read by both
# GNU make (`include`) and bash (`source`), so keep it to plain `KEY=value` with
# ${VAR} expansion only (no $(...), no command substitution).

# Directory holding the project venv's executables (pytest, mkdocs, black, ...).
VENV=${HOME}/.virtualenvs/matamata/bin
